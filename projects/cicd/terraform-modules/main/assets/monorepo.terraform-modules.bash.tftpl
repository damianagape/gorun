#!/bin/bash
set -ex

export TF_IN_AUTOMATION="1"

./scripts/terraform-module test "${project_path}"

terraform -chdir="${project_path}" init -input=false
%{~ if github_event == "pull_request" }
terraform -chdir="${project_path}" plan -input=false
%{~ endif }
%{~ if github_event == "push_branch" }
terraform -chdir="${project_path}" apply -input=false -auto-approve
%{~ endif }
