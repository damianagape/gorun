#!/bin/bash
set -ex

export DOCKER_BUILDKIT="1"

gcloud auth configure-docker "europe-central2-docker.pkg.dev"

./scripts/docker-image build "${project_path}"
./scripts/docker-image test "${project_path}"
%{~ if github_event == "pull_request" }
./scripts/docker-image pre-publish "${project_path}"
%{~ endif }
%{~ if github_event == "push_branch" }
./scripts/docker-image publish "${project_path}"
%{~ endif }
./scripts/docker-image show "${project_path}"
