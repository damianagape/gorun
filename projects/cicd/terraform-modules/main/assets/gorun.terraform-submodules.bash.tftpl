#!/bin/bash
set -ex

./scripts/terraform-submodule build "${project_path}"
./scripts/terraform-submodule test "${project_path}"
%{~ if github_event == "pull_request" }
./scripts/terraform-submodule pre-publish "${project_path}"
%{~ endif }
%{~ if github_event == "push_branch" }
./scripts/terraform-submodule publish "${project_path}"
%{~ endif }
./scripts/terraform-submodule show "${project_path}"
